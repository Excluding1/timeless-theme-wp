{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-preview",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-I",
        "-c",
        "import http.server,socketserver,os;H=type('H',(http.server.SimpleHTTPRequestHandler,),{'__init__':lambda s,*a,**k:http.server.SimpleHTTPRequestHandler.__init__(s,*a,directory='/tmp/timeless-preview',**k)});socketserver.TCPServer(('',int(os.environ.get('PORT',8000))),H).serve_forever()"
      ],
      "port": 8765,
      "autoPort": true
    }
  ]
}
