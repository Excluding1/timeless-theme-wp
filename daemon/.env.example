# Copy this to .env and fill in your secrets.
# DO NOT commit .env — it's gitignored.

# Supabase project — from Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service-role JWT (the scary one — bypasses RLS)
# From Project Settings → API → "service_role" secret
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# Postgres connection string for direct psql access
# Format: postgresql://postgres.<project>:<password>@<region>.pooler.supabase.com:6543/postgres
# From Supabase → Project Settings → Database → "Connection string" → URI
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# Slack incoming webhook — from Slack → Apps → Incoming Webhooks
# Pick a channel like #ceo-daemon
# Format: https://hooks.slack.com/services/<TEAM_ID>/<CHANNEL_ID>/<TOKEN>
SLACK_WEBHOOK_URL=PASTE_FROM_SLACK_INCOMING_WEBHOOKS_APP

# Optional: timezone for cron interpretation. Default Sydney.
TZ=Australia/Sydney

# Optional: agent name prefix shown in agent_runs + Slack messages.
DAEMON_NAME=ceo-daemon-v1
