# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored, never commits secrets.

# Google Places Autocomplete API key (optional — form falls back to plain
# text input if missing).
#
# How to get one:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create a new project (or use existing) → Create credentials → API key
#   3. Enable APIs: "Places API (New)"
#   4. Restrict the key:
#      - HTTP referrer restriction: timelessresurfacing.com.au/* + localhost:5173/*
#      - API restriction: Places API (New) only
#   5. Paste the key below.
#
# Pricing: Autocomplete sessions are FREE since Nov 2024 with session tokens
#          (we already use them). $200 free monthly credit covers ~50,000 sessions.
VITE_GOOGLE_PLACES_KEY=
